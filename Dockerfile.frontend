FROM ghcr.io/cirruslabs/flutter:3.41.7 AS build

WORKDIR /app/mobile-flutter
COPY mobile-flutter/pubspec.yaml mobile-flutter/pubspec.lock ./
RUN flutter pub get --enforce-lockfile
COPY mobile-flutter/ ./
RUN flutter build web --release \
  --dart-define=DATA_SOURCE_MODE=remote \
  --dart-define=API_BASE_URL=

FROM nginx:alpine

COPY docker/frontend-nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/mobile-flutter/build/web /usr/share/nginx/html

EXPOSE 30080
